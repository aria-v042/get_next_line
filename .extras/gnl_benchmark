#!/usr/bin/env bash

make clean && make BUFFER_SIZE="$2"

bench="benchmarks/bench_$1"
if [[ ! -e "$bench" ]]; then
	printf "\"%s\"\n" "$1" > "$bench"
fi
printf "\nBUFFER_SIZE=%s\n" "$2" >> "$bench"

valgrind -s ./test_gnl "$1" 2>&1 | grep -E -o '[0-9,]+ allocs, [0-9,]+ frees, [0-9,]+ bytes allocated' >> "$bench"

make clean
